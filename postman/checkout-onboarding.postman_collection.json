{
  "info": {
    "_postman_id": "89d66f40-b1af-4f34-8f84-3c1f467f1a6a",
    "name": "Checkout Onboarding API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para probar el backend del checkout onboarding desplegado con Serverless."
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{apiBaseUrl}}/health",
          "host": [
            "{{apiBaseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/products",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  const product = data[0];",
                  "  if (product.productId) {",
                  "    pm.environment.set('productId', product.productId);",
                  "  }",
                  "  if (product.priceInCents) {",
                  "    pm.environment.set('productPriceInCents', product.priceInCents);",
                  "  }",
                  "  if (product.currency) {",
                  "    pm.environment.set('currency', product.currency);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Checkout Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/payments/checkout-config",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "payments",
                "checkout-config"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.baseFeeInCents) {",
                  "  pm.environment.set('baseFeeInCents', data.baseFeeInCents);",
                  "}",
                  "if (data.deliveryFeeInCents) {",
                  "  pm.environment.set('deliveryFeeInCents', data.deliveryFeeInCents);",
                  "}",
                  "const productPrice = Number(pm.environment.get('productPriceInCents') || 0);",
                  "const baseFee = Number(data.baseFeeInCents || 0);",
                  "const deliveryFee = Number(data.deliveryFeeInCents || 0);",
                  "if (productPrice > 0) {",
                  "  pm.environment.set('amountInCents', productPrice + baseFee + deliveryFee);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Acceptance Tokens",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/payments/acceptance-tokens",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "payments",
                "acceptance-tokens"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.acceptanceToken) {",
                  "  pm.environment.set('acceptanceToken', data.acceptanceToken);",
                  "}",
                  "if (data.acceptPersonalAuthToken) {",
                  "  pm.environment.set('acceptPersonalAuthToken', data.acceptPersonalAuthToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"customerEmail\": \"{{customerEmail}}\",\n  \"customerName\": \"{{customerName}}\",\n  \"customerPhone\": \"{{customerPhone}}\",\n  \"addressLine1\": \"{{addressLine1}}\",\n  \"city\": \"{{city}}\",\n  \"department\": \"{{department}}\",\n  \"amountInCents\": {{amountInCents}},\n  \"baseFeeInCents\": {{baseFeeInCents}},\n  \"deliveryFeeInCents\": {{deliveryFeeInCents}},\n  \"currency\": \"{{currency}}\"\n}"
            },
            "url": {
              "raw": "{{apiBaseUrl}}/transactions",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.transactionId) {",
                  "  pm.environment.set('transactionId', data.transactionId);",
                  "}",
                  "if (data.reference) {",
                  "  pm.environment.set('transactionReference', data.reference);",
                  "} else if (data.transactionId) {",
                  "  pm.environment.set('transactionReference', data.transactionId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBaseUrl}}/transactions/{{transactionId}}",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "transactions",
                "{{transactionId}}"
              ]
            }
          }
        },
        {
          "name": "Process Transaction Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardToken\": \"{{cardToken}}\",\n  \"acceptanceToken\": \"{{acceptanceToken}}\",\n  \"acceptPersonalAuthToken\": \"{{acceptPersonalAuthToken}}\",\n  \"customerIp\": \"{{customerIp}}\",\n  \"installments\": {{installments}}\n}"
            },
            "description": "Requiere un card token real de Wompi. Puedes obtenerlo desde el frontend o tokenizando manualmente contra Wompi sandbox.",
            "url": {
              "raw": "{{apiBaseUrl}}/transactions/{{transactionId}}/pay",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "transactions",
                "{{transactionId}}",
                "pay"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Assistant",
      "item": [
        {
          "name": "Ask Assistant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"¿Que incluye el total de la compra?\",\n  \"productId\": \"{{productId}}\",\n  \"currentStep\": 1,\n  \"baseFeeInCents\": {{baseFeeInCents}},\n  \"deliveryFeeInCents\": {{deliveryFeeInCents}}\n}"
            },
            "url": {
              "raw": "{{apiBaseUrl}}/assistant",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "assistant"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('assistant returns answer', function () {",
                  "  pm.expect(data.answer).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Simulate Wompi Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const transaction = {",
                  "  id: pm.environment.get('wompiTransactionId') || 'test_wompi_transaction_id',",
                  "  amount_in_cents: Number(pm.environment.get('amountInCents') || 189900),",
                  "  reference: pm.environment.get('transactionReference') || pm.environment.get('transactionId') || 'missing-reference',",
                  "  customer_email: pm.environment.get('customerEmail') || 'test@example.com',",
                  "  currency: pm.environment.get('currency') || 'COP',",
                  "  payment_method_type: 'CARD',",
                  "  status: pm.environment.get('webhookStatus') || 'APPROVED'",
                  "};",
                  "",
                  "const timestamp = Math.floor(Date.now() / 1000);",
                  "const properties = ['transaction.id', 'transaction.reference', 'transaction.status'];",
                  "const values = [transaction.id, transaction.reference, transaction.status].join('');",
                  "const eventsSecret = pm.environment.get('wompiEventsSecret');",
                  "const checksum = CryptoJS.SHA256(`${values}${timestamp}${eventsSecret}`).toString().toUpperCase();",
                  "",
                  "const payload = {",
                  "  event: 'transaction.updated',",
                  "  data: { transaction },",
                  "  signature: {",
                  "    properties,",
                  "    checksum",
                  "  },",
                  "  timestamp",
                  "};",
                  "",
                  "pm.variables.set('computedWebhookPayload', JSON.stringify(payload, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{computedWebhookPayload}}"
            },
            "description": "Simula un webhook firmado con WOMPI_EVENTS_SECRET. Requiere que transactionReference exista en el backend.",
            "url": {
              "raw": "{{apiBaseUrl}}/webhooks/wompi",
              "host": [
                "{{apiBaseUrl}}"
              ],
              "path": [
                "webhooks",
                "wompi"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "computedWebhookPayload",
      "value": ""
    },
    {
      "key": "productPriceInCents",
      "value": ""
    }
  ]
}
